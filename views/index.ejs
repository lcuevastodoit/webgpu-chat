<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/chat.css">
  <link rel="stylesheet" href="/css/modal.css">
  <link rel="stylesheet" href="/css/responsive.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css" id="hljs-theme">
</head>
<body>
  <script>
    // Detect file:// protocol
    if (window.location.protocol === 'file:') {
      document.body.innerHTML = `
        <div style="
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          height: 100vh;
          background: #0d0d0d;
          color: #e4e4e4;
          font-family: 'Inter', sans-serif;
          text-align: center;
          padding: 40px;
        ">
          <h1 style="color: #ffcd6b; margin-bottom: 20px;">⚠️ Server Required</h1>
          <p style="color: #a0a0a0; margin-bottom: 30px;">
            Open via: <code style="color: #64ffa0;">http://localhost:3000</code>
          </p>
        </div>
      `;
      throw new Error('File protocol not supported');
    }
  </script>

  <div class="app">
    <%- include('partials/sidebar') %>

    <div class="overlay" id="overlay"></div>

    <main class="main">
      <%- include('partials/top-nav') %>
      <%- include('partials/mobile-header') %>

      <div class="chat-container" id="chat-container">
        <div class="empty-state" id="empty-state">
          <h2>Gemma 4 E2B</h2>
          <p id="empty-subtitle">Running locally in your browser via WebGPU</p>

          <div id="checking-state" class="hidden">
            <div class="typing-indicator" style="margin: 20px 0;">
              <span></span><span></span><span></span>
            </div>
            <p style="color: var(--text-secondary); font-size: 14px;">Checking local model...</p>
          </div>

          <div id="loading-local-state" class="hidden">
            <div class="progress-bar" style="display: block; margin: 20px auto;">
              <div class="progress-fill" id="local-progress-fill" style="width: 0%;"></div>
            </div>
            <p id="local-progress-text" style="color: var(--accent); font-size: 14px;">Loading local model...</p>
          </div>

          <div id="cdn-load-state" class="hidden">
            <p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 16px;">
              Local model not found. You can:
            </p>
            <button class="load-model-btn" id="download-model-btn" style="margin-bottom: 8px;">
              Download Model (~2.3GB) - Recommended
            </button>
            <button class="load-model-btn" id="load-cdn-btn" style="background: transparent; border: 1px solid var(--border); color: var(--text-secondary);">
              Load from CDN (slower)
            </button>
          </div>

          <div id="ollama-state" class="hidden">
            <p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 8px;">
              Select a model from your Ollama server:
            </p>
            <select id="ollama-model-selector" class="load-model-btn" style="text-align: center; cursor: pointer; margin-bottom: 8px;">
              <option value="">Loading models...</option>
            </select>
            <p id="ollama-status" style="color: var(--accent); font-size: 12px; margin-top: 8px;"></p>
          </div>

          <div class="progress-bar" id="progress-bar" style="display: none;">
            <div class="progress-fill" id="progress-fill"></div>
          </div>
          <div class="progress-text" id="progress-text"></div>
        </div>
      </div>

      <div class="command-badge hidden" id="command-badge">
        <span id="command-badge-icon">💻</span>
        <span id="command-badge-text"></span>
        <button class="remove-cmd" id="remove-cmd">&times;</button>
      </div>

      <div class="input-container" id="input-container" style="display: none;">
        <div class="input-wrapper">
          <div class="commands-dropdown" id="commands-dropdown"></div>

          <div class="input-box">
            <div class="input-actions-left">
              <button class="commands-btn" id="commands-btn" title="Commands (/)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
              </button>
              <button class="web-search-btn" id="web-search-btn" title="Search web (uses context)" onclick="window.app.toggleWebSearch()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="2" y1="12" x2="22" y2="12"></line>
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                </svg>
              </button>
            </div>
            <textarea id="input" rows="1" placeholder="Message Gemma..." disabled></textarea>
            <button class="send-btn" id="send-btn" disabled>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="22" y1="2" x2="11" y2="13"></line>
                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
              </svg>
            </button>
          </div>
          <div class="input-footer">
            Gemma 4 can make mistakes. Consider checking important information.
          </div>
        </div>
      </div>
    </main>
  </div>

  <%- include('partials/modal-commands') %>
  <%- include('partials/search-panel') %>

  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  <script src="/js/runtime-init.js"></script>
  <script type="module" src="/js/app.js"></script>
  <script>
    // Theme toggle functionality
    (function() {
      const savedTheme = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', savedTheme);
      updateHLJSTheme(savedTheme);

      function updateHLJSTheme(theme) {
        const link = document.getElementById('hljs-theme');
        if (link) {
          link.href = theme === 'dark'
            ? 'https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css'
            : 'https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css';
        }
      }

      window.toggleTheme = function() {
        const current = document.documentElement.getAttribute('data-theme') || 'dark';
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        updateHLJSTheme(next);
      };
    })();
  </script>
</body>
</html>
